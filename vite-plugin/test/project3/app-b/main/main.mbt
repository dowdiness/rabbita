///|
using @html {div, text}

///|
pub(all) enum Msg {
  Noop
}

///|
fn view(emit : @rabbita.Emit[Msg], _ : Unit) -> @rabbita.Html {
  ignore(emit)
  div([text("project3 sibling app-b")])
}

///|
fn main {
  let app = @rabbita.new(() => {
    let (model, emit) = @rabbita.create_pure_state(
      (),
      update=fn(_ : Msg, _) { () },
    )
    model.map(model => view(emit, model))
  })
  app.mount("app")
}
